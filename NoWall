using HarmonyLib;
using Photon.Pun;
using UnityEngine;

namespace Sapphire009.RealControlMod
{
    /*
     * 이 클래스는 일반 벽 등반에 아래 두 기능만 적용합니다.
     *
     * 1. 일반 벽을 잡은 상태에서는 스페이스바를 눌러도 손을 놓지 않습니다.
     * 2. 일반 스테미나와 보너스 스테미나가 모두 0이 되면
     *    아래로 미끄러지지 않고 즉시 벽에서 손을 놓습니다.
     *
     * 로프, 덩굴, 클라임 핸들에는 적용하지 않습니다.
     * Reflection은 사용하지 않습니다.
     */
    internal static class NoWall
    {
        private const float StaminaZeroThreshold = 0.0001f;

        private static Character ResolveCharacter(
            Component component)
        {
            if (component == null)
            {
                return null;
            }

            Character character =
                component.GetComponent<Character>();

            if (character == null)
            {
                character =
                    component.GetComponentInParent<Character>();
            }

            return character;
        }

        private static bool IsLocalNormalWallClimbing(
            Character character)
        {
            if (character == null ||
                !character.IsLocal ||
                character.data == null ||
                character.input == null ||
                character.refs == null ||
                character.refs.climbing == null)
            {
                return false;
            }

            return
                character.data.isClimbing &&
                !character.data.isRopeClimbing &&
                !character.data.isVineClimbing &&
                character.data.currentClimbHandle == null;
        }

        private static bool IsStaminaCompletelyEmpty(
            Character character)
        {
            if (character == null ||
                character.data == null)
            {
                return false;
            }

            return
                character.data.currentStamina <=
                    StaminaZeroThreshold &&
                character.data.extraStamina <=
                    StaminaZeroThreshold;
        }

        private static void StopClimbingImmediately(
            CharacterClimbing climbing,
            Character character)
        {
            if (climbing == null ||
                character == null)
            {
                return;
            }

            /*
             * 원본 미끄러짐 값을 제거한 뒤
             * 로컬 캐릭터의 등반을 즉시 종료합니다.
             */
            climbing.playerSlide =
                Vector2.zero;

            climbing.StopClimbingRpc(
                0f);

            /*
             * 로컬에서는 이미 즉시 종료했으므로
             * 다른 플레이어에게만 같은 결과를 전달합니다.
             */
            if (PhotonNetwork.InRoom &&
                character.refs != null &&
                character.refs.view != null)
            {
                character.refs.view.RPC(
                    nameof(CharacterClimbing.StopClimbingRpc),
                    RpcTarget.Others,
                    new object[]
                    {
                        0f
                    });
            }
        }

        [HarmonyPatch(
            typeof(CharacterClimbing),
            "Update")]
        private static class CharacterClimbingUpdatePatch
        {
            /*
             * 원본 Update가 스페이스 입력으로 등반을 종료하지 못하게 합니다.
             *
             * 이미 스테미나가 0이라면 원본 미끄러짐 처리가 실행되기 전에
             * 즉시 손을 놓고 원본 Update 전체를 건너뜁니다.
             */
            [HarmonyPrefix]
            [HarmonyPriority(Priority.First)]
            private static bool Prefix(
                CharacterClimbing __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (!IsLocalNormalWallClimbing(
                        character))
                {
                    return true;
                }

                character.input.jumpWasPressed =
                    false;

                if (!IsStaminaCompletelyEmpty(
                        character))
                {
                    return true;
                }

                StopClimbingImmediately(
                    __instance,
                    character);

                return false;
            }

            /*
             * 원본 등반 스테미너 차감으로 이 프레임에 스테미나가 0이 되면
             * 다음 미끄러짐이 시작되기 전에 즉시 손을 놓습니다.
             */
            [HarmonyPostfix]
            [HarmonyPriority(Priority.Last)]
            private static void Postfix(
                CharacterClimbing __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (!IsLocalNormalWallClimbing(
                        character) ||
                    !IsStaminaCompletelyEmpty(
                        character))
                {
                    return;
                }

                StopClimbingImmediately(
                    __instance,
                    character);
            }
        }
    }
}
