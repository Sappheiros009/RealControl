using HarmonyLib;
using System;
using System.Collections.Generic;
using UnityEngine;

namespace Sapphire009.RealControlMod
{
    /*
     * RealControl의 harmony.PatchAll()에 의해 함께 적용됩니다.
     *
     * 별도의 BepInPlugin을 선언하지 않으므로
     * RealControl.dll 하나 안에서 동작합니다.
     *
     * 동작 목표:
     * 1. RealControl이 실제 스텝 이동에 성공한 순간 이동 방향을 기록합니다.
     * 2. 캐릭터가 해당 방향으로 실제 이동하는 동안만 애니메이션을 재생합니다.
     * 3. 로컬 플레이어의 실제 이동이 끝나면 Animator.speed를 0으로 만듭니다.
     * 4. 다음 스텝이 시작되면 멈췄던 프레임부터 이어서 재생합니다.
     *
     * S 하강 방향 수정 핵심:
     * - playerSlide 또는 매 프레임 변하는 climbPos 자체를 이동 중 판정으로 사용하지 않습니다.
     * - CharacterInput.Sample 안에서 RealControl이 실제로 적용한 climbPos 변화만
     *   새로운 스텝으로 인정합니다.
     * - 이후에는 마지막 스텝 방향으로 진행한 실제 몸 이동량만 검사합니다.
     *
     * Reflection은 사용하지 않습니다.
     */
    internal static class AnimationFlow
    {
        /*
         * CharacterInput.Sample 한 번 안에서 climbPos가 이 값보다 많이 변하면
         * RealControl이 실제 스텝을 적용한 것으로 판단합니다.
         *
         * RealControl의 최소 스텝 거리는 0.01m 이상이므로
         * 0.001m 기준이면 정상 스텝은 놓치지 않습니다.
         */
        private const float AppliedStepSqrMagnitude = 0.000001f;

        /*
         * 마지막 스텝 방향으로 프레임당 이 거리보다 많이 진행해야
         * 실제 이동 중인 것으로 판정합니다.
         *
         * 방향성 있는 진행량만 사용하므로 S 방향의 벽 보정이나
         * 반대 방향 미세 흔들림이 애니메이션을 계속 재생시키지 않습니다.
         */
        private const float MinimumDirectionalMovement = 0.0005f;

        /*
         * 스텝 직후에는 Update와 FixedUpdate 순서 차이로
         * 실제 몸 이동이 아직 0으로 측정될 수 있습니다.
         * 이 시간 동안은 애니메이션 재생을 보장합니다.
         */
        private const float MinimumStepAnimationTime = 0.12f;

        /*
         * 한두 프레임 실제 이동량이 작게 측정되더라도
         * 즉시 끊기지 않도록 짧은 정지 유예시간을 둡니다.
         */
        private const float MovementStopGraceTime = 0.08f;

        private const float MinimumDirectionSqrMagnitude = 0.0001f;
        private const float MinimumAnimationSpeed = 0.01f;

        private static readonly int ClimbJumpAnimationHash =
            Animator.StringToHash("Climb Jump");

        private static readonly int InputXAnimationHash =
            Animator.StringToHash("Input X");

        private static readonly int InputYAnimationHash =
            Animator.StringToHash("Input Y");

        private static readonly Dictionary<int, AnimationFlowState> FlowStates =
            new Dictionary<int, AnimationFlowState>();

        private sealed class AnimationFlowState
        {
            public bool HasPositionSample;
            public bool HasDirectionalPose;
            public bool StepActive;
            public bool IsFrozen;

            public bool HasInputSampleSnapshot;

            public float StepStartedTime;
            public float TimeWithoutMovement;

            public Vector2 LastDirection =
                Vector2.zero;

            public Vector3 InputSampleStartClimbPosition =
                Vector3.zero;

            public Vector3 LastCharacterCenter =
                Vector3.zero;
        }

        private static Character ResolveCharacter(
            Component component)
        {
            if (component == null)
            {
                return null;
            }

            Character character =
                component.GetComponent<Character>();

            if (character == null)
            {
                character =
                    component.GetComponentInParent<Character>();
            }

            return character;
        }

        private static bool IsLocalNormalWallClimbing(
            Character character)
        {
            if (character == null ||
                !character.IsLocal ||
                character.data == null ||
                character.refs == null ||
                character.refs.climbing == null ||
                character.refs.animator == null)
            {
                return false;
            }

            return
                character.data.isClimbing &&
                !character.data.isRopeClimbing &&
                !character.data.isVineClimbing &&
                character.data.currentClimbHandle == null;
        }

        private static AnimationFlowState GetOrCreateState(
            Character character)
        {
            int characterId =
                character.GetInstanceID();

            AnimationFlowState state;

            if (!FlowStates.TryGetValue(
                    characterId,
                    out state))
            {
                state =
                    new AnimationFlowState();

                state.HasPositionSample =
                    true;

                state.LastCharacterCenter =
                    character.Center;

                FlowStates.Add(
                    characterId,
                    state);
            }

            return state;
        }

        private static float GetClimbAnimationSpeed(
            Character character)
        {
            if (character == null ||
                character.data == null)
            {
                return 1f;
            }

            /*
             * PEAK 원본 CharacterAnimations.SetAnimSpeed와 동일하게
             * 등반 중에는 staminaMod를 애니메이션 속도로 사용합니다.
             */
            return Mathf.Max(
                MinimumAnimationSpeed,
                character.data.staminaMod);
        }

        private static bool TryGetWallAxes(
            Character character,
            out Vector3 wallUp,
            out Vector3 wallRight)
        {
            wallUp =
                Vector3.zero;

            wallRight =
                Vector3.zero;

            if (character == null ||
                character.data == null)
            {
                return false;
            }

            Vector3 wallNormal =
                character.data.climbNormal;

            if (wallNormal.sqrMagnitude <=
                MinimumDirectionSqrMagnitude)
            {
                return false;
            }

            wallNormal.Normalize();

            wallUp =
                Vector3.ProjectOnPlane(
                    Vector3.up,
                    wallNormal);

            if (wallUp.sqrMagnitude <=
                MinimumDirectionSqrMagnitude)
            {
                return false;
            }

            wallUp.Normalize();

            /*
             * RealControl.cs가 사용하는 벽의 좌우축과
             * 동일한 계산 순서를 사용합니다.
             */
            wallRight =
                Vector3.Cross(
                    wallNormal,
                    wallUp);

            if (wallRight.sqrMagnitude <=
                MinimumDirectionSqrMagnitude)
            {
                return false;
            }

            wallRight.Normalize();
            return true;
        }

        private static bool TryConvertWorldMovementToInput(
            Character character,
            Vector3 worldMovement,
            out Vector2 inputDirection)
        {
            inputDirection =
                Vector2.zero;

            Vector3 wallUp;
            Vector3 wallRight;

            if (!TryGetWallAxes(
                    character,
                    out wallUp,
                    out wallRight))
            {
                return false;
            }

            /*
             * 벽 위 실제 이동 방향을 PEAK Animator의 Input X/Y로 변환합니다.
             *
             * W: ( 0,  1)
             * S: ( 0, -1)
             * A: (-1,  0)
             * D: ( 1,  0)
             */
            inputDirection =
                new Vector2(
                    Vector3.Dot(
                        worldMovement,
                        wallRight),
                    Vector3.Dot(
                        worldMovement,
                        wallUp));

            if (inputDirection.sqrMagnitude <=
                MinimumDirectionSqrMagnitude)
            {
                inputDirection =
                    Vector2.zero;

                return false;
            }

            inputDirection.Normalize();
            return true;
        }

        private static bool TryConvertInputToWorldDirection(
            Character character,
            Vector2 inputDirection,
            out Vector3 worldDirection)
        {
            worldDirection =
                Vector3.zero;

            if (inputDirection.sqrMagnitude <=
                MinimumDirectionSqrMagnitude)
            {
                return false;
            }

            Vector3 wallUp;
            Vector3 wallRight;

            if (!TryGetWallAxes(
                    character,
                    out wallUp,
                    out wallRight))
            {
                return false;
            }

            worldDirection =
                wallRight * inputDirection.x +
                wallUp * inputDirection.y;

            if (worldDirection.sqrMagnitude <=
                MinimumDirectionSqrMagnitude)
            {
                worldDirection =
                    Vector3.zero;

                return false;
            }

            worldDirection.Normalize();
            return true;
        }

        private static Vector3 GetWallSurfaceMovement(
            Character character,
            Vector3 worldMovement)
        {
            Vector3 wallUp;
            Vector3 wallRight;

            if (!TryGetWallAxes(
                    character,
                    out wallUp,
                    out wallRight))
            {
                return Vector3.zero;
            }

            /*
             * 벽 안팎으로 흔들리는 물리 이동은 무시하고,
             * 벽의 상하좌우 방향으로 실제 이동한 양만 계산합니다.
             */
            return
                wallRight *
                Vector3.Dot(
                    worldMovement,
                    wallRight) +
                wallUp *
                Vector3.Dot(
                    worldMovement,
                    wallUp);
        }

        private static void BeginStepAnimation(
            Character character,
            AnimationFlowState state,
            Vector2 direction)
        {
            if (character == null ||
                state == null ||
                direction.sqrMagnitude <=
                    MinimumDirectionSqrMagnitude)
            {
                return;
            }

            direction.Normalize();

            state.LastDirection =
                direction;

            state.HasDirectionalPose =
                true;

            state.StepActive =
                true;

            state.IsFrozen =
                false;

            state.StepStartedTime =
                Time.unscaledTime;

            state.TimeWithoutMovement =
                0f;

            ResumeAnimation(
                character,
                state);
        }

        private static void ApplyDirectionalAnimation(
            Animator animator,
            Vector2 direction)
        {
            /*
             * 원본 CharacterAnimations.Update는 RealControl이
             * movementInput을 0으로 지운 뒤 Input X/Y를 다시 0으로 만듭니다.
             *
             * 따라서 Postfix에서 방향값을 직접 복구해야
             * PEAK 원본 WASD 등반 Blend Tree가 그대로 작동합니다.
             */
            animator.SetFloat(
                InputXAnimationHash,
                direction.x);

            animator.SetFloat(
                InputYAnimationHash,
                direction.y);
        }

        private static void ResumeAnimation(
            Character character,
            AnimationFlowState state)
        {
            Animator animator =
                character.refs.animator;

            /*
             * Shift용 Climb Jump 애니메이션 대신
             * PEAK 원본 일반 WASD 등반 애니메이션을 사용합니다.
             */
            animator.SetBool(
                ClimbJumpAnimationHash,
                false);

            ApplyDirectionalAnimation(
                animator,
                state.LastDirection);

            /*
             * Animator.Play를 호출하지 않습니다.
             * speed만 복구하므로 이전에 멈춘 normalized time에서
             * 그대로 이어서 재생됩니다.
             */
            animator.speed =
                GetClimbAnimationSpeed(
                    character);

            state.IsFrozen =
                false;
        }

        private static void FreezeAnimation(
            Character character,
            AnimationFlowState state)
        {
            Animator animator =
                character.refs.animator;

            animator.SetBool(
                ClimbJumpAnimationHash,
                false);

            /*
             * CharacterAnimations.Update가 Input X/Y를 0으로
             * 되돌려도 마지막 이동 방향의 손 자세를 유지합니다.
             */
            ApplyDirectionalAnimation(
                animator,
                state.LastDirection);

            /*
             * 현재 재생 중인 정확한 프레임에서 정지합니다.
             * 다음 스텝에서는 speed만 복구하므로 이 프레임부터 이어집니다.
             */
            animator.speed =
                0f;

            state.IsFrozen =
                true;

            state.StepActive =
                false;
        }

        private static void RestoreAndRemoveState(
            Character character)
        {
            if (character == null)
            {
                return;
            }

            int characterId =
                character.GetInstanceID();

            AnimationFlowState state;

            if (!FlowStates.TryGetValue(
                    characterId,
                    out state))
            {
                return;
            }

            if (character.refs != null &&
                character.refs.animator != null)
            {
                /*
                 * 벽을 놓은 뒤에도 Animator.speed가 0으로 남으면
                 * 걷기, 점프 등 캐릭터 전체 애니메이션이 멈추므로
                 * 반드시 원래 속도로 복구합니다.
                 */
                character.refs.animator.speed =
                    1f;
            }

            FlowStates.Remove(
                characterId);
        }

        private static void UpdateAnimationFlow(
            Character character)
        {
            Animator animator =
                character.refs.animator;

            AnimationFlowState state =
                GetOrCreateState(
                    character);

            Vector3 currentCharacterCenter =
                character.Center;

            if (!state.HasPositionSample)
            {
                state.HasPositionSample =
                    true;

                state.LastCharacterCenter =
                    currentCharacterCenter;

                return;
            }

            Vector3 bodyMovement =
                currentCharacterCenter -
                state.LastCharacterCenter;

            Vector3 surfaceBodyMovement =
                GetWallSurfaceMovement(
                    character,
                    bodyMovement);

            bool movingInRequestedDirection =
                false;

            if (state.StepActive &&
                state.HasDirectionalPose)
            {
                Vector3 requestedWorldDirection;

                if (TryConvertInputToWorldDirection(
                        character,
                        state.LastDirection,
                        out requestedWorldDirection))
                {
                    /*
                     * 이동량의 크기만 보지 않고 마지막 스텝 방향으로
                     * 실제 진행한 거리만 사용합니다.
                     *
                     * 특히 S 방향에서는 PEAK의 하강 보정이나 벽 표면의
                     * 미세 흔들림이 있더라도 요청 방향으로 충분히 진행하지
                     * 않았다면 이동 중으로 판정하지 않습니다.
                     */
                    float directionalMovement =
                        Vector3.Dot(
                            surfaceBodyMovement,
                            requestedWorldDirection);

                    movingInRequestedDirection =
                        directionalMovement >
                        MinimumDirectionalMovement;
                }
            }

            if (state.StepActive &&
                state.HasDirectionalPose)
            {
                float stepElapsed =
                    Time.unscaledTime -
                    state.StepStartedTime;

                if (movingInRequestedDirection ||
                    stepElapsed <
                    MinimumStepAnimationTime)
                {
                    state.TimeWithoutMovement =
                        0f;

                    ResumeAnimation(
                        character,
                        state);
                }
                else
                {
                    state.TimeWithoutMovement +=
                        Time.unscaledDeltaTime;

                    if (state.TimeWithoutMovement >=
                        MovementStopGraceTime)
                    {
                        FreezeAnimation(
                            character,
                            state);
                    }
                    else
                    {
                        /*
                         * Update와 FixedUpdate 사이에서 한 프레임 이동량이
                         * 작게 보이더라도 즉시 끊기지 않게 마지막 방향으로
                         * 애니메이션을 잠시 계속 재생합니다.
                         */
                        ResumeAnimation(
                            character,
                            state);
                    }
                }
            }
            else if (state.HasDirectionalPose)
            {
                /*
                 * PEAK 원본 CharacterAnimations.Update가 매 프레임 실행되므로
                 * 이동이 끝난 뒤에도 마지막 방향과 speed 0을 다시 적용합니다.
                 */
                FreezeAnimation(
                    character,
                    state);
            }
            else
            {
                /*
                 * 아직 한 번도 방향 스텝을 실행하지 않았다면
                 * 최초 벽잡기 자세와 속도는 PEAK 원본에 맡깁니다.
                 */
                animator.SetBool(
                    ClimbJumpAnimationHash,
                    false);
            }

            state.LastCharacterCenter =
                currentCharacterCenter;
        }

        /*
         * CharacterInput.Sample 실행 전 climbPos를 저장하고,
         * RealControl의 Sample Postfix가 끝난 뒤 실제 적용된 차이를 확인합니다.
         *
         * 이 방식은 다음 문제를 피합니다.
         * - RealControl이 playerSlide를 0으로 비우므로 playerSlide 기반 판정이 불가능한 문제
         * - PEAK가 FixedUpdate에서 climbPos를 계속 벽 표면에 보정하여
         *   S 방향을 지속 이동으로 오인하는 문제
         */
        [HarmonyPatch(
            typeof(CharacterInput),
            "Sample",
            new Type[]
            {
                typeof(bool)
            })]
        private static class CharacterInputStepDetectionPatch
        {
            [HarmonyPrefix]
            [HarmonyPriority(Priority.First)]
            private static void Prefix(
                CharacterInput __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (!IsLocalNormalWallClimbing(
                        character))
                {
                    return;
                }

                AnimationFlowState state =
                    GetOrCreateState(
                        character);

                state.InputSampleStartClimbPosition =
                    character.data.climbPos;

                state.HasInputSampleSnapshot =
                    true;
            }

            /*
             * RealControl의 CharacterInput.Sample Postfix보다 뒤에서 실행되어야
             * 성공한 스텝으로 변경된 climbPos를 확인할 수 있습니다.
             */
            [HarmonyPostfix]
            [HarmonyPriority(-200)]
            private static void Postfix(
                CharacterInput __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (!IsLocalNormalWallClimbing(
                        character))
                {
                    return;
                }

                AnimationFlowState state =
                    GetOrCreateState(
                        character);

                if (!state.HasInputSampleSnapshot)
                {
                    return;
                }

                state.HasInputSampleSnapshot =
                    false;

                Vector3 appliedStep =
                    character.data.climbPos -
                    state.InputSampleStartClimbPosition;

                if (appliedStep.sqrMagnitude <=
                    AppliedStepSqrMagnitude)
                {
                    return;
                }

                Vector2 appliedDirection;

                if (!TryConvertWorldMovementToInput(
                        character,
                        appliedStep,
                        out appliedDirection))
                {
                    return;
                }

                BeginStepAnimation(
                    character,
                    state,
                    appliedDirection);
            }
        }

        /*
         * PEAK 원본 CharacterAnimations.Update가 모든 Animator 값을
         * 갱신한 뒤 가장 마지막에 실행됩니다.
         */
        [HarmonyPatch(
            typeof(CharacterAnimations),
            "Update")]
        private static class CharacterAnimationsFlowPatch
        {
            [HarmonyPostfix]
            [HarmonyPriority(-200)]
            private static void Postfix(
                CharacterAnimations __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (character == null ||
                    !character.IsLocal)
                {
                    return;
                }

                if (!IsLocalNormalWallClimbing(
                        character))
                {
                    RestoreAndRemoveState(
                        character);

                    return;
                }

                UpdateAnimationFlow(
                    character);
            }
        }

        /*
         * 새로운 벽을 잡을 때 이전 벽에서 저장한
         * 방향과 정지 프레임 상태를 초기화합니다.
         */
        [HarmonyPatch(
            typeof(CharacterClimbing),
            "StartClimbRpc",
            new Type[]
            {
                typeof(Vector3),
                typeof(Vector3)
            })]
        private static class StartClimbAnimationFlowPatch
        {
            [HarmonyPostfix]
            [HarmonyPriority(-200)]
            private static void Postfix(
                CharacterClimbing __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (character == null ||
                    !character.IsLocal)
                {
                    return;
                }

                RestoreAndRemoveState(
                    character);
            }
        }

        /*
         * 벽을 놓거나 추락할 때 Animator.speed를 복구합니다.
         */
        [HarmonyPatch(
            typeof(CharacterClimbing),
            nameof(CharacterClimbing.StopClimbingRpc),
            new Type[]
            {
                typeof(float)
            })]
        private static class StopClimbAnimationFlowPatch
        {
            [HarmonyPostfix]
            [HarmonyPriority(-200)]
            private static void Postfix(
                CharacterClimbing __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (character == null ||
                    !character.IsLocal)
                {
                    return;
                }

                RestoreAndRemoveState(
                    character);
            }
        }
    }
}
