using BepInEx;
using BepInEx.Configuration;
using BepInEx.Logging;
using HarmonyLib;
using System;
using System.Collections.Generic;
using UnityEngine;

[BepInPlugin(PluginGUID, PluginName, PluginVersion)]
public sealed class RealControlPlugin : BaseUnityPlugin
{
    public const string PluginGUID = "Sapphire009.RealControl";
    public const string PluginName = "RealControl";
    public const string PluginVersion = "1.0.2";

    private const string BuildMarker =
        "DirectionalAlternatingInput-Stamina-R3";

    private const float NormalGrabDetectionWindow = 0.75f;
    private const float MinimumDirectionSqrMagnitude = 0.0001f;
    private const float StepStaminaCost = 0.05f;

    internal static ManualLogSource ModLogger;

    private static ConfigEntry<float> upStepDistance;
    private static ConfigEntry<float> sideStepDistance;
    private static ConfigEntry<float> downStepDistance;
    private static ConfigEntry<bool> logSuccessfulSteps;

    private static readonly Dictionary<int, InputState> InputStates =
        new Dictionary<int, InputState>();

    private Harmony harmony;

    private enum ExpectedHand
    {
        Left,
        Right
    }

    private enum StepDirection
    {
        Up,
        Down,
        Left,
        Right
    }

    private sealed class InputState
    {
        public bool WasControlledWallClimbing;

        public float LastPrimaryPressedTime =
            float.NegativeInfinity;

        public ExpectedHand NextHand =
            ExpectedHand.Left;
    }

    private void Awake()
    {
        ModLogger = Logger;

        upStepDistance = Config.Bind(
            "Climb Step",
            "UpStepDistance",
            0.45f,
            "W를 누른 상태에서 올바른 좌클릭/우클릭 교대 입력 1회당 위로 이동할 거리입니다.");

        sideStepDistance = Config.Bind(
            "Climb Step",
            "SideStepDistance",
            0.45f,
            "A 또는 D를 누른 상태에서 올바른 좌클릭/우클릭 교대 입력 1회당 좌우로 이동할 거리입니다.");

        downStepDistance = Config.Bind(
            "Climb Step",
            "DownStepDistance",
            0.45f,
            "S를 누른 상태에서 올바른 좌클릭/우클릭 교대 입력 1회당 아래로 이동할 거리입니다.");

        logSuccessfulSteps = Config.Bind(
            "Debug",
            "LogSuccessfulSteps",
            false,
            "true이면 적용된 등반 스텝을 로그에 기록합니다.");

        harmony =
            new Harmony(PluginGUID);

        harmony.PatchAll();

        Logger.LogInfo(
            $"{PluginName} {PluginVersion} loaded. " +
            $"Developer=Sapphire009. Build={BuildMarker}.");
    }

    private void OnDestroy()
    {
        InputStates.Clear();

        if (harmony != null)
        {
            harmony.UnpatchSelf();
            harmony = null;
        }

        ModLogger = null;
    }

    private static InputState GetOrCreateState(
        CharacterInput characterInput)
    {
        int inputId =
            characterInput.GetInstanceID();

        InputState state;

        if (!InputStates.TryGetValue(
                inputId,
                out state))
        {
            state =
                new InputState();

            InputStates.Add(
                inputId,
                state);
        }

        return state;
    }

    private static bool IsControlledWallClimbing(
        Character character)
    {
        if (character == null ||
            character.data == null ||
            character.refs == null ||
            character.refs.climbing == null)
        {
            return false;
        }

        return
            character.data.isClimbing &&
            !character.data.isRopeClimbing &&
            !character.data.isVineClimbing &&
            character.data.currentClimbHandle == null;
    }

    private static bool ReadUpHeld(
        Vector2 sampledMovement)
    {
        if (CharacterInput.action_moveForward != null)
        {
            return
                CharacterInput.action_moveForward.IsPressed();
        }

        return sampledMovement.y > 0.5f;
    }

    private static bool ReadLeftHeld(
        Vector2 sampledMovement)
    {
        if (CharacterInput.action_moveLeft != null)
        {
            return
                CharacterInput.action_moveLeft.IsPressed();
        }

        return sampledMovement.x < -0.5f;
    }

    private static bool ReadRightHeld(
        Vector2 sampledMovement)
    {
        if (CharacterInput.action_moveRight != null)
        {
            return
                CharacterInput.action_moveRight.IsPressed();
        }

        return sampledMovement.x > 0.5f;
    }

    private static bool ReadDownHeld(
        Vector2 sampledMovement)
    {
        if (CharacterInput.action_moveBackward != null)
        {
            return
                CharacterInput.action_moveBackward.IsPressed();
        }

        return sampledMovement.y < -0.5f;
    }

    private static bool TryGetHeldDirection(
        bool upHeld,
        bool leftHeld,
        bool rightHeld,
        bool downHeld,
        out StepDirection stepDirection)
    {
        stepDirection =
            StepDirection.Up;

        int heldDirectionCount = 0;

        if (upHeld)
        {
            stepDirection =
                StepDirection.Up;

            heldDirectionCount++;
        }

        if (downHeld)
        {
            stepDirection =
                StepDirection.Down;

            heldDirectionCount++;
        }

        if (leftHeld)
        {
            stepDirection =
                StepDirection.Left;

            heldDirectionCount++;
        }

        if (rightHeld)
        {
            stepDirection =
                StepDirection.Right;

            heldDirectionCount++;
        }

        /*
         * 방향키가 없거나 둘 이상 동시에 눌린 경우에는
         * 방향을 확정하지 않습니다.
         */
        return heldDirectionCount == 1;
    }

    private static void BeginControlledClimb(
        Character character,
        InputState state)
    {
        bool startedByNormalLeftClick =
            Time.unscaledTime -
            state.LastPrimaryPressedTime <=
            NormalGrabDetectionWindow;

        /*
         * 일반 벽잡기의 좌클릭을 첫 손동작으로 계산합니다.
         *
         * 정상적으로 좌클릭으로 벽을 잡았다면
         * 다음 이동 입력은 우클릭입니다.
         *
         * 자동 벽잡기처럼 좌클릭 없이 잡았다면
         * 다음 이동 입력은 좌클릭입니다.
         */
        state.NextHand =
            startedByNormalLeftClick
                ? ExpectedHand.Right
                : ExpectedHand.Left;

        character.refs.climbing.playerSlide =
            Vector2.zero;

        state.WasControlledWallClimbing =
            true;
    }

    private static bool HasEnoughStepStamina(
        Character character)
    {
        if (character == null ||
            character.data == null)
        {
            return false;
        }

        float totalStamina =
            Mathf.Max(
                0f,
                character.data.currentStamina) +
            Mathf.Max(
                0f,
                character.data.extraStamina);

        return
            totalStamina + 0.0001f >=
            StepStaminaCost;
    }

    private static bool ConsumeStepStamina(
        Character character)
    {
        if (!HasEnoughStepStamina(character))
        {
            return false;
        }

        float remainingCost =
            StepStaminaCost;

        /*
         * 일반 스테미너를 먼저 소모합니다.
         */
        float regularStaminaUsed =
            Mathf.Min(
                Mathf.Max(
                    0f,
                    character.data.currentStamina),
                remainingCost);

        character.data.currentStamina -=
            regularStaminaUsed;

        remainingCost -=
            regularStaminaUsed;

        /*
         * 일반 스테미너만으로 0.05f를 채우지 못한 경우
         * 남은 비용을 보너스 스테미너에서 소모합니다.
         */
        if (remainingCost > 0f)
        {
            float bonusStaminaUsed =
                Mathf.Min(
                    Mathf.Max(
                        0f,
                        character.data.extraStamina),
                    remainingCost);

            character.data.extraStamina -=
                bonusStaminaUsed;

            remainingCost -=
                bonusStaminaUsed;
        }

        character.ClampStamina();

        character.data.extraStamina =
            Mathf.Max(
                0f,
                character.data.extraStamina);

        /*
         * 벽을 잡고 있는 동안 스테미너가 즉시
         * 자동 회복되지 않도록 사용 시간을 초기화합니다.
         */
        character.data.sinceUseStamina =
            0f;

        /*
         * 직접 스테미너 필드를 수정했으므로
         * UI 게이지도 즉시 갱신합니다.
         */
        if (GUIManager.instance != null &&
            GUIManager.instance.bar != null)
        {
            GUIManager.instance.bar.ChangeBar();
        }

        return remainingCost <= 0.0001f;
    }

    private static bool TryApplyStep(
        Character character,
        StepDirection stepDirection)
    {
        if (!IsControlledWallClimbing(character))
        {
            return false;
        }

        Vector3 wallNormal =
            character.data.climbNormal;

        if (wallNormal.sqrMagnitude <
            MinimumDirectionSqrMagnitude)
        {
            return false;
        }

        wallNormal.Normalize();

        Vector3 wallUp =
            Vector3.ProjectOnPlane(
                Vector3.up,
                wallNormal);

        if (wallUp.sqrMagnitude <
            MinimumDirectionSqrMagnitude)
        {
            return false;
        }

        wallUp.Normalize();

        Vector3 wallRight =
            Vector3.Cross(
                wallNormal,
                wallUp);

        if (wallRight.sqrMagnitude <
            MinimumDirectionSqrMagnitude)
        {
            return false;
        }

        wallRight.Normalize();

        Vector3 stepVector =
            Vector3.zero;

        switch (stepDirection)
        {
            case StepDirection.Up:
                stepVector =
                    wallUp *
                    Mathf.Max(
                        0.01f,
                        upStepDistance.Value);
                break;

            case StepDirection.Down:
                stepVector =
                    -wallUp *
                    Mathf.Max(
                        0.01f,
                        downStepDistance.Value);
                break;

            case StepDirection.Left:
                stepVector =
                    -wallRight *
                    Mathf.Max(
                        0.01f,
                        sideStepDistance.Value);
                break;

            case StepDirection.Right:
                stepVector =
                    wallRight *
                    Mathf.Max(
                        0.01f,
                        sideStepDistance.Value);
                break;
        }

        if (stepVector.sqrMagnitude <
            MinimumDirectionSqrMagnitude)
        {
            return false;
        }

        /*
         * 실제 이동이 확정된 입력에만
         * 스테미너 0.05f를 소모합니다.
         *
         * 스테미너가 부족하면 이동과 손 교대를
         * 모두 실행하지 않습니다.
         */
        if (!ConsumeStepStamina(character))
        {
            return false;
        }

        /*
         * PEAK 원본 등반은 climbPos를
         * 캐릭터의 등반 목표점으로 사용합니다.
         */
        character.refs.climbing.playerSlide =
            Vector2.zero;

        character.data.climbPos +=
            stepVector;

        character.data.sinceGrounded =
            0f;

        if (logSuccessfulSteps.Value)
        {
            ModLogger?.LogInfo(
                $"[RealControl] Step={stepDirection}, " +
                $"Distance={stepVector.magnitude:0.000}, " +
                $"StaminaCost={StepStaminaCost:0.00}, " +
                $"CurrentStamina={character.data.currentStamina:0.000}, " +
                $"ExtraStamina={character.data.extraStamina:0.000}, " +
                $"ClimbPos={character.data.climbPos}");
        }

        return true;
    }

    private static void ProcessControlledClimbInput(
        CharacterInput characterInput,
        Character character,
        InputState state,
        bool upHeld,
        bool leftHeld,
        bool rightHeld,
        bool downHeld)
    {
        bool primaryPressed =
            characterInput.usePrimaryWasPressed;

        bool secondaryPressed =
            characterInput.useSecondaryWasPressed;

        /*
         * W/A/S/D를 계속 누르고 있어도
         * PEAK 원본의 연속 등반 이동이 발생하지 않게 합니다.
         */
        characterInput.movementInput =
            Vector2.zero;

        /*
         * 좌클릭과 우클릭을 교대로 사용해야 하므로
         * 좌클릭 해제에 의한 원본 벽 놓기를 무시합니다.
         */
        characterInput.usePrimaryWasReleased =
            false;

        bool expectedClickPressed =
            state.NextHand == ExpectedHand.Left
                ? primaryPressed
                : secondaryPressed;

        if (expectedClickPressed)
        {
            StepDirection stepDirection;

            /*
             * 정확히 하나의 방향키가 눌렸고
             * 스테미너 차감과 이동이 성공한 경우에만
             * 다음 손으로 변경합니다.
             */
            if (TryGetHeldDirection(
                    upHeld,
                    leftHeld,
                    rightHeld,
                    downHeld,
                    out stepDirection) &&
                TryApplyStep(
                    character,
                    stepDirection))
            {
                state.NextHand =
                    state.NextHand ==
                    ExpectedHand.Left
                        ? ExpectedHand.Right
                        : ExpectedHand.Left;
            }
        }

        /*
         * 등반 중 마우스 입력은
         * RealControl에서 처리했으므로 소비합니다.
         */
        characterInput.usePrimaryWasPressed =
            false;

        characterInput.usePrimaryIsPressed =
            false;

        characterInput.useSecondaryWasPressed =
            false;

        characterInput.useSecondaryIsPressed =
            false;

        characterInput.useSecondaryWasReleased =
            false;
    }

    [HarmonyPatch(
        typeof(CharacterInput),
        "Sample",
        new Type[]
        {
            typeof(bool)
        })]
    private static class CharacterInputSamplePatch
    {
        [HarmonyPostfix]
        [HarmonyPriority(Priority.Last)]
        [HarmonyAfter(
            new string[]
            {
                "Sapphire009.WASDX",
                "Sapphire009.JumpingPEAK"
            })]
        private static void Postfix(
            CharacterInput __instance)
        {
            if (__instance == null)
            {
                return;
            }

            Character character =
                __instance.GetComponent<Character>();

            if (character == null ||
                !character.IsLocal)
            {
                return;
            }

            InputState state =
                GetOrCreateState(__instance);

            /*
             * RealControl에서 movementInput을 지우기 전에
             * 현재 방향 입력을 먼저 보관합니다.
             */
            Vector2 sampledMovement =
                __instance.movementInput;

            bool upHeld =
                ReadUpHeld(sampledMovement);

            bool leftHeld =
                ReadLeftHeld(sampledMovement);

            bool rightHeld =
                ReadRightHeld(sampledMovement);

            bool downHeld =
                ReadDownHeld(sampledMovement);

            bool controlledWallClimbing =
                IsControlledWallClimbing(character);

            if (!controlledWallClimbing)
            {
                /*
                 * 일반 벽을 잡기 위해 누른 좌클릭 시간을 저장합니다.
                 */
                if (__instance.usePrimaryWasPressed)
                {
                    state.LastPrimaryPressedTime =
                        Time.unscaledTime;
                }

                state.WasControlledWallClimbing =
                    false;

                return;
            }

            if (!state.WasControlledWallClimbing)
            {
                BeginControlledClimb(
                    character,
                    state);
            }

            ProcessControlledClimbInput(
                __instance,
                character,
                state,
                upHeld,
                leftHeld,
                rightHeld,
                downHeld);
        }
    }
}
