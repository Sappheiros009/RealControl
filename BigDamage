using HarmonyLib;
using System;
using System.Collections.Generic;
using UnityEngine;

namespace Sapphire009.RealControlMod
{
    /*
     * RealControl의 harmony.PatchAll()에 의해 함께 적용됩니다.
     *
     * BigDamage.cs의 역할:
     *
     * 일반 벽을 잡고 있던 로컬 플레이어가
     * 스테미너 0으로 인해 벽에서 손을 놓고 추락한 경우에만,
     * 착지할 때 PEAK 원본이 계산한 낙사 Injury를 3배로 만듭니다.
     *
     * 이 클래스에는 아래 기능을 넣지 않습니다.
     *
     * - WASD 및 좌우클릭 교대 입력
     * - 9f 이동
     * - 이동 1회당 스테미너 0.05f 소모
     * - 벽 정지 중 스테미너 소모 차단
     * - 스페이스바 손 놓기 차단
     * - 애니메이션 제어
     * - ClimbJump 딜레이 변경
     *
     * Reflection은 사용하지 않습니다.
     */
    internal static class BigDamage
    {
        private const float ExhaustedFallDamageMultiplier = 3f;

        /*
         * PEAK 원본 Character.OutOfStamina()와 동일한 기준입니다.
         */
        private const float RegularStaminaEmptyThreshold = 0.005f;
        private const float ExtraStaminaEmptyThreshold = 0.001f;

        /*
         * 텔레포트나 씬 전환 등으로 정상 착지가 발생하지 않았을 때
         * 오래된 강화 상태가 다음 낙하에 남지 않게 하는 안전 시간입니다.
         */
        private const float ArmedStateLifetime = 30f;

        /*
         * Key:
         * 스테미너 0 상태로 일반 벽에서 손을 놓은 캐릭터의 Instance ID
         *
         * Value:
         * 강화 낙하 상태가 시작된 Time.unscaledTime
         */
        private static readonly Dictionary<int, float>
            ExhaustedWallFallCharacters =
                new Dictionary<int, float>();

        /*
         * 현재 CharacterMovement.CheckFallDamage 안에서
         * 실제 낙사 데미지를 계산하고 있는 캐릭터입니다.
         *
         * CharacterAfflictions.AddStatus에 전달되는 Injury 중에서
         * 이 상태에 해당하는 호출만 3배로 변경합니다.
         */
        private static readonly HashSet<int>
            FallDamageInProgress =
                new HashSet<int>();

        private static Character ResolveCharacter(
            Component component)
        {
            if (component == null)
            {
                return null;
            }

            Character character =
                component.GetComponent<Character>();

            if (character == null)
            {
                character =
                    component.GetComponentInParent<Character>();
            }

            return character;
        }

        /*
         * 로프, 덩굴, ClimbHandle은 제외하고
         * 일반 벽 등반만 판정합니다.
         */
        private static bool IsLocalNormalWallClimbing(
            Character character)
        {
            if (character == null ||
                !character.IsLocal ||
                character.data == null ||
                character.refs == null ||
                character.refs.climbing == null)
            {
                return false;
            }

            return
                character.data.isClimbing &&
                !character.data.isRopeClimbing &&
                !character.data.isVineClimbing &&
                character.data.currentClimbHandle == null;
        }

        private static bool IsStaminaCompletelyEmpty(
            Character character)
        {
            if (character == null ||
                character.data == null)
            {
                return false;
            }

            return
                character.data.currentStamina <
                    RegularStaminaEmptyThreshold &&
                character.data.extraStamina <
                    ExtraStaminaEmptyThreshold;
        }

        private static void ArmExhaustedWallFall(
            Character character)
        {
            if (character == null)
            {
                return;
            }

            int characterId =
                character.GetInstanceID();

            ExhaustedWallFallCharacters[characterId] =
                Time.unscaledTime;

            FallDamageInProgress.Remove(
                characterId);
        }

        private static void ClearExhaustedWallFall(
            Character character)
        {
            if (character == null)
            {
                return;
            }

            ClearExhaustedWallFall(
                character.GetInstanceID());
        }

        private static void ClearExhaustedWallFall(
            int characterId)
        {
            ExhaustedWallFallCharacters.Remove(
                characterId);

            FallDamageInProgress.Remove(
                characterId);
        }

        private static bool IsExhaustedWallFallArmed(
            Character character)
        {
            if (character == null ||
                !character.IsLocal)
            {
                return false;
            }

            int characterId =
                character.GetInstanceID();

            float armedTime;

            if (!ExhaustedWallFallCharacters.TryGetValue(
                    characterId,
                    out armedTime))
            {
                return false;
            }

            float armedDuration =
                Time.unscaledTime -
                armedTime;

            if (armedDuration >
                ArmedStateLifetime)
            {
                ClearExhaustedWallFall(
                    characterId);

                return false;
            }

            return true;
        }

        /*
         * NoWall.cs가 스테미너 0을 감지하면
         * CharacterClimbing.StopClimbingRpc를 호출합니다.
         *
         * Prefix에서는 원본 메서드가 isClimbing을 false로 바꾸기 전이므로,
         * "일반 벽을 잡고 있었고 스테미너가 0이었다"는 원인을
         * 정확히 저장할 수 있습니다.
         */
        [HarmonyPatch(
            typeof(CharacterClimbing),
            nameof(CharacterClimbing.StopClimbingRpc),
            new Type[]
            {
                typeof(float)
            })]
        private static class StopClimbingRpcPatch
        {
            [HarmonyPrefix]
            [HarmonyPriority(Priority.First)]
            private static void Prefix(
                CharacterClimbing __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                if (!IsLocalNormalWallClimbing(
                        character))
                {
                    return;
                }

                if (!IsStaminaCompletelyEmpty(
                        character))
                {
                    return;
                }

                ArmExhaustedWallFall(
                    character);
            }
        }

        /*
         * PEAK 원본 CharacterMovement.CheckFallDamage는
         * 착지 시 낙하 시간과 속도를 기준으로 원래 데미지를 계산합니다.
         *
         * 이 Prefix는 PEAK의 계산식을 바꾸지 않고,
         * 현재 계산이 스테미너 0 벽 추락에 해당하는지만 표시합니다.
         */
        [HarmonyPatch(
            typeof(CharacterMovement),
            "CheckFallDamage",
            new Type[]
            {
            })]
        private static class CharacterMovementCheckFallDamagePatch
        {
            [HarmonyPrefix]
            [HarmonyPriority(Priority.First)]
            private static void Prefix(
                CharacterMovement __instance,
                out int __state)
            {
                __state =
                    -1;

                Character character =
                    ResolveCharacter(
                        __instance);

                if (!IsExhaustedWallFallArmed(
                        character))
                {
                    return;
                }

                int characterId =
                    character.GetInstanceID();

                FallDamageInProgress.Add(
                    characterId);

                __state =
                    characterId;
            }

            [HarmonyPostfix]
            [HarmonyPriority(Priority.Last)]
            private static void Postfix(
                int __state)
            {
                if (__state < 0)
                {
                    return;
                }

                /*
                 * CheckFallDamage는 착지 1회당 한 번 처리됩니다.
                 * 실제 데미지가 발생하지 않을 정도로 낮게 떨어졌어도
                 * 다음 일반 낙하에 강화 상태가 남지 않게 즉시 종료합니다.
                 */
                ClearExhaustedWallFall(
                    __state);
            }
        }

        /*
         * PEAK 원본 낙사 데미지는 최종적으로 다음 호출을 사용합니다.
         *
         * CharacterAfflictions.AddStatus(
         *     STATUSTYPE.Injury,
         *     원본 낙사 데미지,
         *     false,
         *     true,
         *     true)
         *
         * CheckFallDamage가 실행 중인 동일 캐릭터의 Injury만 3배로 바꿉니다.
         * 독, 추위, 적 공격, 충돌 등 다른 Injury에는 적용되지 않습니다.
         */
        [HarmonyPatch(
            typeof(CharacterAfflictions),
            nameof(CharacterAfflictions.AddStatus),
            new Type[]
            {
                typeof(CharacterAfflictions.STATUSTYPE),
                typeof(float),
                typeof(bool),
                typeof(bool),
                typeof(bool)
            })]
        private static class CharacterAfflictionsAddStatusPatch
        {
            [HarmonyPrefix]
            [HarmonyPriority(Priority.First)]
            private static void Prefix(
                CharacterAfflictions __instance,
                CharacterAfflictions.STATUSTYPE __0,
                ref float __1)
            {
                if (__instance == null ||
                    __instance.character == null ||
                    !__instance.character.IsLocal)
                {
                    return;
                }

                if (__0 !=
                    CharacterAfflictions.STATUSTYPE.Injury)
                {
                    return;
                }

                if (__1 <= 0f)
                {
                    return;
                }

                int characterId =
                    __instance.character.GetInstanceID();

                if (!FallDamageInProgress.Contains(
                        characterId))
                {
                    return;
                }

                __1 *=
                    ExhaustedFallDamageMultiplier;
            }
        }

        /*
         * 아주 낮은 높이에서 착지하면 PEAK 원본 Land가
         * CheckFallDamage를 호출하지 않을 수 있습니다.
         *
         * Land가 끝난 뒤 강화 상태를 정리하여
         * 다음 일반 낙하가 잘못 3배 처리되는 것을 막습니다.
         */
        [HarmonyPatch(
            typeof(CharacterMovement),
            "Land")]
        private static class CharacterMovementLandPatch
        {
            [HarmonyPostfix]
            [HarmonyPriority(Priority.Last)]
            private static void Postfix(
                CharacterMovement __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                ClearExhaustedWallFall(
                    character);
            }
        }

        /*
         * 착지하지 않고 다른 벽을 다시 잡은 경우
         * 이전 추락의 강화 상태를 제거합니다.
         */
        [HarmonyPatch(
            typeof(CharacterClimbing),
            "StartClimbRpc",
            new Type[]
            {
                typeof(Vector3),
                typeof(Vector3)
            })]
        private static class StartClimbRpcPatch
        {
            [HarmonyPostfix]
            private static void Postfix(
                CharacterClimbing __instance)
            {
                Character character =
                    ResolveCharacter(
                        __instance);

                ClearExhaustedWallFall(
                    character);
            }
        }

        /*
         * 캐릭터 오브젝트가 파괴될 때 정적 상태를 정리합니다.
         */
        [HarmonyPatch(
            typeof(Character),
            "OnDestroy")]
        private static class CharacterOnDestroyPatch
        {
            [HarmonyPrefix]
            private static void Prefix(
                Character __instance)
            {
                ClearExhaustedWallFall(
                    __instance);
            }
        }
    }
}
